{
	"name": "agy-cli-proxy",
	"version": "1.0.0",
	"description": "Simplified Gemini API proxy for Antigravity",
	"main": "dist/index.js",
	"type": "module",
	"scripts": {
		"build": "tsc",
		"start": "node --use-env-proxy dist/index.js",
		"dev": "nodemon --exec \"tsx --use-env-proxy\" src/index.ts",
		"lint": "biome check .",
		"format": "biome check --write ."
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"cors": "^2.8.5",
		"express": "^4.19.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^25.9.2",
		"nodemon": "^3.1.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	}
}
